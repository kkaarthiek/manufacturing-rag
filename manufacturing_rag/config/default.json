{
  "_comment": "Always hosted: OpenAI embeddings (text-embedding-3-large) + GPT-4o LLM + Qdrant vector DB. Set OPENAI_API_KEY and ANTHROPIC_API_KEY env vars before running.",
  "models": {
    "provider_mode": "hosted",
    "embeddings": "openai:text-embedding-3-large",
    "embedding_dim": 3072,
    "reranker": "llm",
    "llm": "gpt-4o",
    "vector_store": "qdrant",
    "temperature": 0.0,
    "self_consistency_n": 3
  },
  "thresholds": {
    "recall_ks": [1, 3, 5, 10],
    "abstain_score": 1.0,
    "ingestion_recall_target": 1.0,
    "index_coverage_target": 1.0,
    "retrieval_recall_target": 1.0
  }
}
